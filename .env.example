# ============================================
# Auto Deploy 설정 파일 (.env)
# ============================================
# 이 파일을 복사하여 .env로 만들고 값을 수정하세요.
#   cp .env.example .env
# ============================================

# ──────────────────────────────────────
# [필수] GitHub 설정
# ──────────────────────────────────────
GITHUB_USERNAME=jongool30
GITHUB_REPO=auto-deploy
GITHUB_BRANCH=master

# ──────────────────────────────────────
# [필수] Docker 이미지 설정
# ──────────────────────────────────────
DOCKER_REGISTRY=ghcr.io
IMAGE_NAME=${DOCKER_REGISTRY}/${GITHUB_USERNAME}/${GITHUB_REPO}
IMAGE_TAG=latest

# ──────────────────────────────────────
# [선택] 앱 설정
# ──────────────────────────────────────
APP_NAME=auto-deploy-api
APP_VERSION=1.0.0
APP_PORT=8000
APP_REPLICAS=2
ENVIRONMENT=production

# ──────────────────────────────────────
# [선택] K3d 클러스터 설정
# ──────────────────────────────────────
CLUSTER_NAME=automation-cluster
K3D_LB_HTTP_PORT=8080
K3D_LB_HTTPS_PORT=8443
K3D_AGENTS=1

# ──────────────────────────────────────
# [선택] K8s 네임스페이스
# ──────────────────────────────────────
K8S_NAMESPACE=auto-deploy

# ──────────────────────────────────────
# [선택] ArgoCD 설정
# ──────────────────────────────────────
ARGOCD_PORT=9090

# ──────────────────────────────────────
# [선택] Docker Compose 포트
# ──────────────────────────────────────
COMPOSE_APP_PORT=8000
COMPOSE_ARGOCD_PORT=9090
